# Neon PostgreSQL (get from https://neon.tech)
# Use sslmode=verify-full to avoid pg SSL deprecation warning (Neon requires SSL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# Groq API key for AI summarization, explain, define, flashcards (get from https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Optional: persistent disk path on Render (e.g. /opt/render/project/src/uploads)
# UPLOAD_DIR=/opt/render/project/src/uploads

# Supabase Storage for books (free tier, no card required)
# Create buckets "books" and "covers" in Supabase Dashboard → Storage, set to Public
# SUPABASE_URL=https://xxxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key

# TTS is powered by Edge TTS (Microsoft Azure Neural speech via WebSocket).
# No memory-heavy models needed — audio is streamed from Microsoft's servers.

# Optional: path to Calibre ebook-convert (for EPUB→PDF conversion)
# Windows: C:\Program Files\Calibre2\ebook-convert.exe
# Mac: /Applications/calibre.app/Contents/MacOS/ebook-convert
# EBOOK_CONVERT_PATH=
